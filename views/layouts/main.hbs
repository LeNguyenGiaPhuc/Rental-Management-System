<!DOCTYPE html>
<html>
<head>
  <title>RoomRental</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>

<body>

  <nav class="navbar navbar-light bg-white border-bottom px-4 fixed-top shadow-sm">
    <span class="navbar-brand fw-bold">RoomRental</span>
    <button onclick="openModal()" class="btn btn-outline-dark btn-sm">Login</button>
</nav>

  {{{body}}}

  {{> loginModal}}

</body>
</html>

<script>
  function openModal() {
    document.getElementById("loginModal").style.display = "flex";
    document.getElementById("loginFormContainer").style.display = "block";
    document.getElementById("forgotPasswordFormContainer").style.display = "none";
  }

  function closeModal() {
    document.getElementById("loginModal").style.display = "none";
  }

  function toggleForgotForm() {
    const loginForm = document.getElementById("loginFormContainer");
    const forgotForm = document.getElementById("forgotPasswordFormContainer");
    
    if (loginForm.style.display === "none") {
      loginForm.style.display = "block";
      forgotForm.style.display = "none";
    } else {
      loginForm.style.display = "none";
      forgotForm.style.display = "block";
    }
  }
</script>

<script>
  // Request OTP from the modal forgot-password form
  let otpCooldownTimer = null;
  function showForgotMessage(text, isError = true) {
    const el = document.getElementById('forgotMsg');
    if (!el) return;
    el.style.display = 'block';
    el.style.color = isError ? '#d63384' : '#198754';
    el.textContent = text;
  }

  function clearForgotMessage() {
    const el = document.getElementById('forgotMsg');
    if (!el) return;
    el.style.display = 'none';
    el.textContent = '';
  }

  async function requestOtpFromModal() {
    const emailEl = document.getElementById('forgotEmail');
    const btn = document.getElementById('btnGetOtp');
    if (!emailEl || !btn) return;

      let email = (emailEl.value || '').trim();
      // fallback 1: attribute value (in case server rendered value attribute but property empty)
      if (!email) {
        const attr = (emailEl.getAttribute && emailEl.getAttribute('value')) || '';
        if (attr && attr.trim()) {
          email = attr.trim();
        }
      }
      // fallback 2: find any input[name="email"] inside forgot form or globally
      if (!email) {
        const alt = document.querySelector('#forgotPasswordFormContainer input[name="email"]') || document.querySelector('input[name="email"]');
        if (alt) {
          email = (alt.value || alt.getAttribute('value') || '').trim();
        }
      }
      // fallback 3: placeholder (unlikely) or innerText of nearby label
      if (!email) {
        const ph = emailEl.placeholder || '';
        if (ph && ph.includes('@')) {
          email = ph.trim();
        }
      }

      if (!email) {
          showForgotMessage('Please enter your email', true);
        return;
      }

    btn.disabled = true;
    btn.textContent = 'Sending...';
    clearForgotMessage();

    try {
      const res = await fetch('/auth/forgot', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email })
      });

      const data = await res.json().catch(() => null);
      if (res.ok && data && data.success) {
        showForgotMessage(data.message || 'OTP sent — check your email (and spam).', false);
        startOtpCooldown(60);
        document.getElementById('forgotOtp').focus();
      } else if (res.status === 429) {
        showForgotMessage((data && data.message) || 'Please wait before requesting another code', true);
        startOtpCooldown(5);
      } else {
        showForgotMessage((data && data.message) || 'Error sending OTP, try again later', true);
        btn.disabled = false;
        btn.textContent = 'Get OTP';
      }
    } catch (err) {
      console.error('requestOtpFromModal error', err);
      showForgotMessage('Connection error, check the server', true);
      btn.disabled = false;
      btn.textContent = 'Get OTP';
    }
  }

  function startOtpCooldown(seconds) {
    const btn = document.getElementById('btnGetOtp');
    if (!btn) return;
    let remaining = seconds;
    btn.disabled = true;
    btn.textContent = `Wait ${remaining}s`;
    if (otpCooldownTimer) clearInterval(otpCooldownTimer);
    otpCooldownTimer = setInterval(() => {
      remaining -= 1;
      if (remaining <= 0) {
        clearInterval(otpCooldownTimer);
        otpCooldownTimer = null;
        btn.disabled = false;
        btn.textContent = 'Get OTP';
        return;
      }
      btn.textContent = `Wait ${remaining}s`;
    }, 1000);
  }
</script>

<script>
  // Generic login message in modal
  function showLoginMessage(text, isError = true) {
    const el = document.getElementById('loginMsg');
    if (!el) return;
    el.style.display = 'block';
    el.style.color = isError ? '#d63384' : '#198754';
    el.textContent = text;
  }

  // Intercept login form submit to show message instead of blank page
  (function attachAuthHandlers() {
    const loginForm = document.getElementById('loginForm');
    if (loginForm) {
      loginForm.addEventListener('submit', async function (e) {
        e.preventDefault();
        showLoginMessage('', false);
        const form = e.currentTarget;
        const fd = new FormData(form);
        const body = { phone: fd.get('phone'), password: fd.get('password') };
        const submitBtn = form.querySelector('button[type="submit"]');
        if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Logging in...'; }
        try {
          const res = await fetch(form.action, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
          const data = await res.json().catch(() => null);
          if (res.ok && data && data.success) {
            window.location.href = data.redirect || '/';
            return;
          }
          showLoginMessage((data && data.message) || 'Login failed', true);
        } catch (err) {
          console.error('Login error', err);
          showLoginMessage('Connection error, try again', true);
        } finally {
          if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Login'; }
        }
      });
    }

    const verifyForm = document.getElementById('forgotVerifyForm');
    if (verifyForm) {
      verifyForm.addEventListener('submit', async function (e) {
        e.preventDefault();
        clearForgotMessage();
        const fd = new FormData(e.currentTarget);
        const email = fd.get('email');
        const code = fd.get('code');
        const newPassword = fd.get('newPassword');
        const confirm = fd.get('confirmPassword');
        if (!email || !code || !newPassword) {
          showForgotMessage('Please fill in all fields', true);
          return;
        }
        if (newPassword !== confirm) {
          showForgotMessage('Passwords do not match', true);
          return;
        }
        const btn = verifyForm.querySelector('button[type="submit"]');
        if (btn) { btn.disabled = true; btn.textContent = 'Updating...'; }
        try {
          const res = await fetch(verifyForm.action, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email, code, newPassword }) });
          const data = await res.json().catch(() => null);
          if (res.ok && data && data.success) {
            showForgotMessage(data.message || 'Password updated', false);
            setTimeout(() => {
              // switch back to login form
              toggleForgotForm();
            }, 1200);
            return;
          }
          showForgotMessage((data && data.message) || 'Failed to update password', true);
        } catch (err) {
          console.error('Reset password error', err);
          showForgotMessage('Connection error, try again', true);
        } finally {
          if (btn) { btn.disabled = false; btn.textContent = 'Update Password'; }
        }
      });
    }
  })();
</script>