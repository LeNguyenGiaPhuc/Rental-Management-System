<div class="mb-4">
  <h3 class="fw-bold d-flex align-items-center text-dark m-0">
    <i class="bi bi-wrench-adjustable text-primary me-3 fs-3"></i> Request Service
  </h3>
</div>

<div class="row g-4">
  <div class="col-lg-6">
    <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
      <h5 class="fw-bold mb-4 text-dark">Submit New Request</h5>
      <form action="/tenant/requests" method="POST">
        
        <div class="mb-3">
          <label class="form-label fw-semibold small text-dark">Request Type</label>
          <select id="requestTypeSelect" class="form-select bg-light border-0 py-2 text-secondary shadow-none" name="type" required>
            <option selected disabled>Select type</option>
            <option value="Repair">Repair</option>
            <option value="Installation">Installation</option>
            <option value="Maintenance">Maintenance</option>
            <option value="Cleaning">Cleaning</option>
            <option value="Support">Support</option>
            <option value="Other">Other</option>
          </select>
        </div>
        
        <div class="mb-3">
          <label class="form-label fw-semibold small text-dark">Priority</label>
          <select class="form-select bg-light border-0 py-2 text-secondary shadow-none" name="priority" required>
            <option selected disabled>Select priority</option>
            <option value="Low Priority">Low Priority</option>
            <option value="Medium Priority">Medium Priority</option>
            <option value="High Priority">High Priority</option>
          </select>
        </div>

        <div class="mb-3">
          <label class="form-label fw-semibold small text-dark">Title</label>
          <input name="title" type="text" class="form-control bg-light border-0 py-2 shadow-none" placeholder="Brief description of the issue" required>
        </div>

        <div id="estimatedCostGroup" class="mb-3" style="display:none;">
          <label class="form-label fw-semibold small text-dark">Select Equipment</label>
          
          <div class="d-flex flex-column gap-2">
            <div class="form-check bg-light rounded-3 p-3">
              <input class="form-check-input installation-item" type="checkbox" 
                    id="item_ac" value="300000">
              <label class="form-check-label fw-semibold" for="item_ac">
                Air Conditioner <span class="text-muted fw-normal">— 300,000 VND</span>
              </label>
            </div>
            <div class="form-check bg-light rounded-3 p-3">
              <input class="form-check-input installation-item" type="checkbox" 
                    id="item_fridge" value="200000">
              <label class="form-check-label fw-semibold" for="item_fridge">
                Fridge <span class="text-muted fw-normal">— 200,000 VND</span>
              </label>
            </div>
            <div class="form-check bg-light rounded-3 p-3">
              <input class="form-check-input installation-item" type="checkbox" 
                    id="item_fan" value="50000">
              <label class="form-check-label fw-semibold" for="item_fan">
                Fan <span class="text-muted fw-normal">— 50,000 VND</span>
              </label>
            </div>
          </div>

          <div class="mt-3">
            <label class="form-label fw-semibold small text-dark">Estimated Cost</label>
            <input id="estimatedCostInput" name="estimatedCost" type="number" 
                  class="form-control bg-light border-0 py-2 shadow-none fw-bold" 
                  placeholder="0" min="0" readonly>
          </div>
        </div>

        <div class="mb-4">
          <label class="form-label fw-semibold small text-dark">Detailed Description</label>
          <textarea name="description" class="form-control bg-light border-0 py-2 shadow-none" rows="3" placeholder="Provide detailed information about your request..." required></textarea>
        </div>

        <button type="submit" class="btn btn-dark w-100 fw-bold py-2 rounded-3 mt-2">
          <i class="bi bi-send me-2"></i> Submit Request
        </button>
      </form>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const typeSelect = document.getElementById('requestTypeSelect');
      const costGroup = document.getElementById('estimatedCostGroup');
      const costInput = document.getElementById('estimatedCostInput');

      if (!typeSelect || !costGroup || !costInput) return;

      function updateEstimatedCostVisibility() {
        const isInstallation = typeSelect.value === 'Installation';
        costGroup.style.display = isInstallation ? 'block' : 'none';
        costInput.disabled = !isInstallation;
        if (!isInstallation) {
          costInput.value = '';
        }
      }

      typeSelect.addEventListener('change', updateEstimatedCostVisibility);
      updateEstimatedCostVisibility();

      document.querySelectorAll('.installation-item').forEach(cb => {
        cb.addEventListener('change', function() {
          let total = 0;
          document.querySelectorAll('.installation-item:checked').forEach(cb => {
            total += Number(cb.value);
          });
          costInput.value = total;
        });
      });
    });
  </script>

  <div class="col-lg-6">
    <div class="px-2"> <h5 class="fw-bold mb-4 text-dark">My Requests</h5>
      <div class="d-flex flex-column gap-3">
        
        {{#each requests}}
        <div class="card border-0 shadow-sm rounded-4 p-4 position-relative">
          
          {{#if (eq status "Completed")}}
            <i class="bi bi-check-circle text-success position-absolute top-0 end-0 m-4 fs-5"></i>
          {{/if}}

          <h6 class="fw-bold mb-1 text-dark">{{title}}</h6>
          <p class="text-muted small mb-3">{{description}}</p>
          
          <div class="d-flex align-items-center gap-2 flex-wrap">
            <span class="badge rounded-pill px-3 py-1 fw-normal
              {{#if (eq status "Pending")}}bg-warning bg-opacity-10 text-warning
              {{else if (eq status "In Progress")}}bg-primary bg-opacity-10 text-primary
              {{else}}bg-success bg-opacity-10 text-success{{/if}}">
              {{status}}
            </span>
            
            <span class="badge rounded-pill px-3 py-1 fw-normal border-0
              {{#if (eq priority "High Priority")}}text-danger bg-danger bg-opacity-10
              {{else if (eq priority "Medium Priority")}}text-warning bg-warning bg-opacity-10
              {{else if (eq priority "Low Priority")}}text-success bg-success bg-opacity-10
              {{else}}text-secondary bg-secondary bg-opacity-10{{/if}}">
              {{priority}}
            </span>

            <span class="badge rounded-pill px-3 py-1 fw-normal bg-secondary bg-opacity-10 text-secondary">{{type}}</span>

            {{#if estimatedCost}}
              <span class="badge rounded-pill px-3 py-1 fw-normal bg-info bg-opacity-10 text-info">{{formatVND estimatedCost}}</span>
            {{/if}}

            <span class="text-muted small ms-auto fw-medium">{{date}}</span>
          </div>
        </div>
        {{/each}}

      </div>
    </div>
  </div>
</div>